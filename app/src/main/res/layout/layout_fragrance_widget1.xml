<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>
        <variable
            name="model"
            type="com.geely.hvac.viewmodel.MainViewModel" />
    </data>

<RelativeLayout
    android:id="@id/root"
    android:layout_width="224.0dip"
    android:layout_height="224.0dip"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@id/bg_img"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@mipmap/widget_fragrance_bg_on1" />

    <TextView
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/widget_fragrance_label_left"
        android:layout_marginTop="@dimen/widget_fragrance_label_top"
        android:fontFamily="@font/alibaba_puhuiti_medium"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/widget_fragrance_label"
        android:textColor="@color/widget_fragrance_label_color_on"
        android:textFontWeight="500"
        android:textSize="32.0sp" />

    <ImageView
        android:id="@id/fragrance_widget_level"
        android:layout_width="@dimen/fragrance_widget_level_img_width"
        android:layout_height="@dimen/fragrance_widget_level_img_height"
        android:layout_marginStart="128.0dip"
        android:layout_marginTop="@dimen/fragrance_widget_level_img_top"
        android:src="@mipmap/fragrance_widget_level_0" />
</RelativeLayout>
</layout>