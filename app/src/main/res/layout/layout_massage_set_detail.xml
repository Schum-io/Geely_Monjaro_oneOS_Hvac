<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

        <variable
            name="model"
            type="com.geely.hvac.viewmodel.MainViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@color/seat_bg_dialog_color"
        android:tag="layout/layout_massage_set_detail_0">

        <com.geely.hvac.component.ConstraintLayoutWithBg
            android:layout_width="@dimen/seat_set_detail_content_width"
            android:layout_height="@dimen/seat_set_detail_content_height"
            android:layout_marginBottom="@dimen/seat_set_detail_content_bottom"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:normalColor="@color/alert_dialog_bg"
            app:radius="@dimen/alert_dialog_bg_radius">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@id/close"
                android:layout_width="@dimen/buy_fragrance_close_width"
                android:layout_height="@dimen/buy_fragrance_close_height"
                android:layout_marginStart="@dimen/buy_fragrance_close_left"
                android:layout_marginTop="@dimen/buy_fragrance_close_top"
                android:src="@drawable/buy_fragrance_close"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.geely.toolchain.hmi.view.HmiImageView
                android:id="@id/seat_mode"
                android:layout_width="@dimen/massage_set_pic_width"
                android:layout_height="@dimen/massage_set_pic_height"
                android:layout_marginStart="696.0dip"
                android:layout_marginTop="@dimen/massage_set_pic_top"
                android:tag="binding_1"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.geely.hvac.component.SeatMassageAnimate
                android:layout_width="@dimen/massage_set_pic_width"
                android:layout_height="@dimen/massage_set_pic_height"
                android:tag="binding_2"
                app:layout_constraintBottom_toBottomOf="@id/seat_mode"
                app:layout_constraintLeft_toLeftOf="@id/seat_mode"
                app:layout_constraintRight_toRightOf="@id/seat_mode"
                app:layout_constraintTop_toTopOf="@id/seat_mode" />

            <com.geely.hvac.component.MassageLevel
                android:layout_width="@dimen/massage_set_level_width"
                android:layout_height="@dimen/massage_set_level_height"
                android:layout_marginStart="@dimen/massage_set_level_left"
                android:layout_marginBottom="@dimen/massage_set_level_bottom"
                android:tag="binding_3"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:selectorActiveColor="@color/fragrance_active_txt_color"
                app:selectorIndicatorBg="@color/massage_level_indicator_bg"
                app:selectorIndicatorHeight="@dimen/massage_set_level_indicator_height"
                app:selectorIndicatorRadius="@dimen/massage_set_level_indicator_radius"
                app:selectorIndicatorWidth="@dimen/massage_set_level_indicator_width"
                app:selectorItemBg="@color/massage_level_bg"
                app:selectorItemHeight="@dimen/massage_set_level_item_height"
                app:selectorItemRadius="@dimen/massage_set_level_item_radius"
                app:selectorItemWidth="@dimen/massage_set_level_item_width"
                app:selectorLabel="@string/massage_level_label"
                app:selectorNormalColor="@color/main_tab_item_txt_color_unactive"
                app:selectorTextSize="@dimen/fragrance_level_text_size" />

            <com.geely.hvac.component.MassageType
                android:layout_width="@dimen/massage_set_type_wrap_width"
                android:layout_height="wrap_content"
                android:layout_marginStart="168.0dip"
                android:layout_marginTop="96.0dip"
                android:layout_marginBottom="96.0dip"
                android:tag="binding_4"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </com.geely.hvac.component.ConstraintLayoutWithBg>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>