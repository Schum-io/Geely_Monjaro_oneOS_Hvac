<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="model"
            type="com.geely.hvac.component.AcSetItem" />
    </data>

<merge
    android:layout_width="fill_parent"
    android:layout_height="wrap_content">

    <View
        android:id="@id/switcher_bottom_click"
        android:layout_width="@dimen/ac_set_item_switch_click_space"
        android:layout_height="@dimen/ac_set_item_switch_click_space"
        android:tag="layout/layout_ac_set_item_0"
        app:layout_constraintBottom_toBottomOf="@id/switcher"
        app:layout_constraintEnd_toEndOf="@id/switcher"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="@id/switcher"
        app:layout_constraintTop_toTopOf="@id/switcher" />

    <com.geely.hvac.component.Switch
        android:id="@id/switcher"
        android:layout_width="@dimen/auto_fragrance_remind_switch_width"
        android:layout_height="@dimen/auto_fragrance_remind_switch_height"
        android:layout_marginStart="@dimen/ac_set_item_switch_margin_start"
        android:tag="layout/layout_ac_set_item_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:switchBgActiveColor="@color/switch_active_bg"
        app:switchBgUnActiveColor="@color/switch_unactive_bg"
        app:switchIndicatorActiveColor="@color/switch_indicator_active"
        app:switchIndicatorRadius="@dimen/auto_fragrance_remind_switch_indicator_radius"
        app:switchIndicatorUnActiveColor="@color/switch_indicator_unactive" />

    <com.geely.toolchain.hmi.view.HmiTextView
        android:id="@id/title"
        android:layout_width="wrap_content"
        android:layout_height="44.0dip"
        android:layout_marginStart="@dimen/ac_set_item_title_margin_left"
        android:fontFamily="@font/alibaba_puhuiti_medium"
        android:lineHeight="44.0dip"
        android:tag="layout/layout_ac_set_item_2"
        android:textColor="@color/ac_set_item_title"
        android:textSize="@dimen/ac_set_item_title_txt_size"
        app:layout_constraintLeft_toRightOf="@id/switcher"
        app:layout_constraintTop_toTopOf="parent" />

    <com.geely.toolchain.hmi.view.HmiTextView
        android:id="@id/desc"
        android:layout_width="wrap_content"
        android:layout_height="40.0dip"
        android:layout_marginStart="@dimen/ac_set_item_title_margin_left"
        android:layout_marginTop="@dimen/ac_set_item_desc_margin_top"
        android:fontFamily="@font/alibaba_puhuiti_regular"
        android:lineHeight="@dimen/ac_set_item_desc_line_height"
        android:maxWidth="@dimen/ac_set_item_desc_max_width"
        android:tag="layout/layout_ac_set_item_3"
        android:textColor="@color/ac_set_item_desc"
        android:textSize="@dimen/ac_set_item_desc_txt_size"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/switcher"
        app:layout_constraintTop_toBottomOf="@id/title" />
</merge>
</layout>