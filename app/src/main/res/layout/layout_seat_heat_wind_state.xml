<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="model"
            type="com.geely.hvac.viewmodel.MainViewModel" />
    </data>

<merge
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.geely.hvac.component.ViewWithBackground
        android:id="@id/bg"
        android:layout_width="@dimen/seat_heat_wind_status_bg_width"
        android:layout_height="@dimen/seat_heat_wind_status_bg_height"
        android:tag="layout/layout_seat_heat_wind_state_0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:radius="@dimen/seat_heat_wind_status_bg_radius" />

    <com.geely.toolchain.hmi.view.HmiImageView
        android:id="@id/img"
        android:layout_width="@dimen/seat_heat_wind_status_width"
        android:layout_height="@dimen/seat_heat_wind_status_height"
        android:tag="layout/layout_seat_heat_wind_state_1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</merge>
</layout>